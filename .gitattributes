# Normalize line endings: store text as LF in the repo, check out per-platform.
* text=auto

# Explicit text types
*.cs        text
*.cshtml    text
*.csproj    text
*.props     text
*.targets   text
*.sln       text
*.json      text
*.css       text
*.js        text
*.md        text
*.config    text
*.editorconfig text

# Binary assets (never normalize)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
