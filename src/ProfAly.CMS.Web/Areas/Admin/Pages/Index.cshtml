@page
@using System.Globalization
@inject Microsoft.Extensions.Localization.IStringLocalizer<ProfAly.CMS.Web.SharedResource> L
@model ProfAly.CMS.Web.Areas.Admin.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="page-title">Welcome@(string.IsNullOrEmpty(Model.AdminName) ? "" : ", " + Model.AdminName)</h1>
<p class="page-sub">Admin console shell — content management is added in the upcoming stages.</p>

<div class="card-grid mb-4">
    <div class="tile">
        <h3>Content</h3>
        <p>Books, publications, research, theses, projects, videos, resources, enrichment. <span class="badge-soon">soon</span></p>
    </div>
    <div class="tile">
        <h3>Profile &amp; Pages</h3>
        <p>Biography, qualifications, skills, experience, memberships, activities, teaching. <span class="badge-soon">soon</span></p>
    </div>
    <div class="tile">
        <h3>Media Library</h3>
        <p>Images and PDFs with usage tracking. <span class="badge-soon">soon</span></p>
    </div>
    <a class="tile" asp-page="/Messages/Index" style="text-decoration:none; color:inherit; display:block">
        <h3>@L["Messages_Title"]</h3>
        <p class="mb-2">
            <strong style="font-size:1.6rem">@Model.TotalMessages</strong> @L["Msg_Total"]
            @if (Model.UnreadMessages > 0) { <span class="badge text-bg-danger ms-2">@Model.UnreadMessages @L["Msg_Unread"]</span> }
        </p>
        @if (Model.LatestMessages.Count > 0)
        {
            <ul class="list-unstyled mb-0 small">
                @foreach (var m in Model.LatestMessages)
                {
                    <li class="d-flex justify-content-between gap-2 @(m.IsRead ? "text-muted" : "fw-semibold")">
                        <span class="text-truncate">@m.Name — @(string.IsNullOrEmpty(m.Subject) ? "—" : m.Subject)</span>
                        <span class="text-muted flex-shrink-0" dir="ltr">@m.CreatedUtc.ToString("MM-dd", CultureInfo.InvariantCulture)</span>
                    </li>
                }
            </ul>
        }
        else { <p class="text-muted mb-0 small">@L["Msg_NoMessages"]</p> }
    </a>
    <div class="tile">
        <h3>Statistics</h3>
        <p>Views, downloads, plays, top content. <span class="badge-soon">soon</span></p>
    </div>
    <div class="tile">
        <h3>Backup &amp; Restore</h3>
        <p>Export/import the full backup set. <span class="badge-soon">soon</span></p>
    </div>
</div>

<div class="tile" style="max-width:540px">
    <h3>Session</h3>
    <p class="mb-1">Signed in as <strong>@Model.AdminName</strong> (role: SuperAdmin).</p>
    <p class="mb-0">Interface language: <strong>@Model.CurrentCulture</strong>. Theme can be toggled from the top bar.</p>
</div>
