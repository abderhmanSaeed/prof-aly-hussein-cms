@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L
@{
    var page = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;

    // (Label, Page route, active-prefix, enabled). Page=null → placeholder ("soon").
    var groups = new (string Title, (string Label, string? Page, string Prefix, bool Enabled)[] Items)[]
    {
        ("", new[]
        {
            ("Dashboard", (string?)"/Index", "/Index", true),
        }),
        ("Content — Profile & Pages", new[]
        {
            ("Home", (string?)null, "", false),
            (L["Profile_Title"].Value, "/Profile/Index", "/Profile", true),
            (L["Qualifications_Title"].Value, "/Qualifications/Index", "/Qualifications", true),
            (L["Skills_Title"].Value, "/Skills/Index", "/Skills", true),
            ("Experience", (string?)null, "", false),
            (L["Memberships_Title"].Value, "/Memberships/Index", "/Memberships", true),
            (L["Stats_Title"].Value, "/Stats/Index", "/Stats", true),
            (L["Credibility_Title"].Value, "/Credibility/Index", "/Credibility", true),
            ("Activities", (string?)null, "", false),
            ("Teaching", (string?)null, "", false),
        }),
        ("Content — Collections", new[]
        {
            ("Research", (string?)null, "", false), ("Publications", (string?)null, "", false),
            ("Books", (string?)null, "", false), ("Theses", (string?)null, "", false),
            ("Projects", (string?)null, "", false), ("Videos", (string?)null, "", false),
            ("Resources", (string?)null, "", false), ("Enrichment", (string?)null, "", false),
        }),
        ("Organization", new[] { ("Categories", (string?)null, "", false), ("Media Library", (string?)null, "", false) }),
        ("Site", new[]
        {
            ("Header", (string?)null, "", false), ("Footer", (string?)null, "", false),
            ("Profile & Contact", (string?)null, "", false), ("Appearance / Theme", (string?)null, "", false),
            ("SEO", (string?)null, "", false), ("Redirects", (string?)null, "", false),
        }),
        ("Communication", new[] { ("Contact Messages", (string?)null, "", false) }),
        ("System", new[]
        {
            ("Site Statistics", (string?)null, "", false), ("Backup & Restore", (string?)null, "", false),
            ("Account & Security", (string?)null, "", false),
        }),
    };

    bool IsActive(string prefix) =>
        prefix == "/Index" ? page == "/Index" : page.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
}

<div class="admin-brand">
    <span class="mark" aria-hidden="true">ع</span>
    <span>
        <span class="name d-block">Prof. Aly Hussein</span>
        <span class="sub">Admin Console</span>
    </span>
</div>

<nav aria-label="Admin">
    @foreach (var group in groups)
    {
        <div class="nav-group">
            @if (!string.IsNullOrEmpty(group.Title))
            {
                <div class="nav-group-title">@group.Title</div>
            }
            @foreach (var item in group.Items)
            {
                if (item.Enabled && item.Page is not null)
                {
                    <a class="nav-link-item @(IsActive(item.Prefix) ? "active" : "")" asp-area="Admin" asp-page="@item.Page">
                        <span>@item.Label</span>
                    </a>
                }
                else
                {
                    <span class="nav-link-item disabled" aria-disabled="true">
                        <span>@item.Label</span>
                        <span class="soon">soon</span>
                    </span>
                }
            }
        </div>
    }
</nav>
