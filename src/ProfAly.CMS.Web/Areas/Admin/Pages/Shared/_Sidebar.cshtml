@using Microsoft.AspNetCore.Mvc.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<ProfAly.CMS.Web.SharedResource> L
@{
    var page = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var currentType = ViewContext.RouteData.Values["type"]?.ToString()
                      ?? Context.Request.Query["type"].ToString();

    // (Label, Page, Prefix, RouteType, Enabled). Page=null → placeholder ("soon").
    var groups = new (string Title, (string Label, string? Page, string Prefix, string? RouteType, bool Enabled)[] Items)[]
    {
        ("", new[] { ("Dashboard", (string?)"/Index", "/Index", (string?)null, true) }),
        ("Content — Profile & Pages", new[]
        {
            ("Home", (string?)null, "", (string?)null, false),
            (L["Profile_Title"].Value, "/Profile/Index", "/Profile", null, true),
            (L["Qualifications_Title"].Value, "/Qualifications/Index", "/Qualifications", null, true),
            (L["Skills_Title"].Value, "/Skills/Index", "/Skills", null, true),
            (L["Experience_Title"].Value, "/Experience/Index", "/Experience", null, true),
            (L["Memberships_Title"].Value, "/Memberships/Index", "/Memberships", null, true),
            (L["Stats_Title"].Value, "/Stats/Index", "/Stats", null, true),
            (L["Credibility_Title"].Value, "/Credibility/Index", "/Credibility", null, true),
            (L["Activities_Title"].Value, "/Activities/Index", "/Activities", null, true),
            (L["Teaching_Title"].Value, "/Teaching/Index", "/Teaching", null, true),
        }),
        ("Content — Collections", new[]
        {
            (L["Research_Title"].Value, (string?)"/Content/Index", "/Content", (string?)"ResearchPaper", true),
            (L["Publications_Title"].Value, "/Content/Index", "/Content", "Publication", true),
            (L["Books_Title"].Value, "/Content/Index", "/Content", "Book", true),
            (L["Theses_Title"].Value, "/Theses/Index", "/Theses", null, true),
            ("Projects", null, "", null, false),
        }),
        ("Digital Resources", new[]
        {
            (L["Videos_Title"].Value, (string?)"/Videos/Index", "/Videos", (string?)null, true),
            (L["Enrichment_Title"].Value, "/Content/Index", "/Content", "EnrichmentItem", true),
            (L["RecommendedBooks_Title"].Value, "/Content/Index", "/Content", "RecommendedBook", true),
            (L["Events_Title"].Value, "/Events/Index", "/Events", null, true),
        }),
        ("Organization", new[]
        {
            (L["Categories_Title"].Value, (string?)"/Categories/Index", "/Categories", (string?)null, true),
            ("Media Library", null, "", null, false),
        }),
        ("Site", new[]
        {
            ("Header", (string?)null, "", (string?)null, false), ("Footer", null, "", null, false),
            ("Profile & Contact", null, "", null, false), ("Appearance / Theme", null, "", null, false),
            ("SEO", null, "", null, false), ("Redirects", null, "", null, false),
        }),
        ("Communication", new[] { (L["Messages_Title"].Value, (string?)"/Messages/Index", "/Messages", (string?)null, true) }),
        ("System", new[]
        {
            ("Site Statistics", (string?)null, "", (string?)null, false),
            ("Backup & Restore", "/Database/Backup", "/Database/Backup", null, true),
            ("Account & Security", null, "", null, false),
        }),
    };

    bool IsActive(string prefix, string? routeType)
    {
        if (prefix == "/Index")
        {
            return page == "/Index";
        }
        if (!page.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }
        return routeType is null || string.Equals(routeType, currentType, StringComparison.OrdinalIgnoreCase);
    }
}

<div class="admin-brand">
    <span class="mark" aria-hidden="true">ع</span>
    <span>
        <span class="name d-block">Prof. Aly Hussein</span>
        <span class="sub">Admin Console</span>
    </span>
</div>

<nav aria-label="Admin">
    @foreach (var group in groups)
    {
        <div class="nav-group">
            @if (!string.IsNullOrEmpty(group.Title))
            {
                <div class="nav-group-title">@group.Title</div>
            }
            @foreach (var item in group.Items)
            {
                if (item.Enabled && item.Page is not null)
                {
                    <a class="nav-link-item @(IsActive(item.Prefix, item.RouteType) ? "active" : "")"
                       asp-area="Admin" asp-page="@item.Page" asp-route-type="@item.RouteType">
                        <span>@item.Label</span>
                    </a>
                }
                else
                {
                    <span class="nav-link-item disabled" aria-disabled="true">
                        <span>@item.Label</span>
                        <span class="soon">soon</span>
                    </span>
                }
            }
        </div>
    }
</nav>
