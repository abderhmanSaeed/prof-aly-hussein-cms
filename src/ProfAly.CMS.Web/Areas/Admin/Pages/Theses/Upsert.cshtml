@page
@using Microsoft.AspNetCore.Mvc.Localization
@using ProfAly.CMS.Domain.Enums
@model ProfAly.CMS.Web.Areas.Admin.Pages.Theses.UpsertModel
@inject IViewLocalizer L
@{
    ViewData["Title"] = (Model.IsEdit ? L["Edit"].Value : L["CreateNew"].Value) + " · " + L["Theses_Title"].Value;
    var cultures = Model.Cultures;
}

<h1 class="page-title">@ViewData["Title"]</h1>

<form method="post" enctype="multipart/form-data" class="tile" style="max-width:880px">
    <div asp-validation-summary="All" class="alert alert-danger py-2 px-3 small" style="@(ViewData.ModelState.IsValid ? "display:none" : "")"></div>
    <input type="hidden" asp-for="Input.Id" />

    <div class="row g-3 mb-3">
        <div class="col-auto" style="max-width:200px">
            <label asp-for="Input.RelationshipType" class="form-label">@L["F_Relationship"]</label>
            <select asp-for="Input.RelationshipType" class="form-select">
                <option value="@RelationshipType.Supervised">@L["Rel_Supervised"]</option>
                <option value="@RelationshipType.Examined">@L["Rel_Examined"]</option>
                <option value="@RelationshipType.Ongoing">@L["Rel_Ongoing"]</option>
            </select>
        </div>
        <div class="col-auto" style="max-width:160px">
            <label asp-for="Input.DegreeLevel" class="form-label">@L["F_Degree"]</label>
            <select asp-for="Input.DegreeLevel" class="form-select">
                <option value="@DegreeLevel.Master">@L["Deg_Master"]</option>
                <option value="@DegreeLevel.PhD">@L["Deg_PhD"]</option>
            </select>
        </div>
        <div class="col-auto" style="max-width:120px">
            <label asp-for="Input.PublicationYear" class="form-label">@L["F_PublicationYear"]</label>
            <input asp-for="Input.PublicationYear" type="number" class="form-control" dir="ltr" />
        </div>
        <div class="col-auto">
            <label class="form-label d-block">&nbsp;</label>
            <div class="form-check mt-2">
                <input asp-for="Input.IsPublished" class="form-check-input" />
                <label asp-for="Input.IsPublished" class="form-check-label">@L["F_Published"]</label>
            </div>
        </div>
    </div>

    <div class="mb-3" style="max-width:420px">
        <label class="form-label">@L["F_Pdf"]</label>
        @if (!string.IsNullOrEmpty(Model.PdfPath)) { <div class="mb-1"><a href="@Model.PdfPath" target="_blank" rel="noopener">PDF</a></div> }
        <input asp-for="Input.PdfFile" type="file" accept="application/pdf" class="form-control" />
        <span asp-validation-for="Input.PdfFile" class="text-danger small"></span>
    </div>

    <ul class="nav nav-tabs" role="tablist">
        @for (var i = 0; i < cultures.Count; i++)
        {
            var c = cultures[i];
            var label = c == "ar" ? L["LangArabic"] : c == "fr" ? L["LangFrench"] : L["LangEnglish"];
            <li class="nav-item"><button class="nav-link @(i == 0 ? "active" : "")" type="button" data-bs-toggle="tab" data-bs-target="#t-@c">@label</button></li>
        }
    </ul>
    <div class="tab-content border border-top-0 p-3 mb-3">
        @for (var i = 0; i < cultures.Count; i++)
        {
            var c = cultures[i];
            <div class="tab-pane fade @(i == 0 ? "show active" : "")" id="t-@c" dir="@(c == "ar" ? "rtl" : "ltr")">
                <input type="hidden" asp-for="Input.Translations[i].Culture" />
                <div class="mb-2"><label asp-for="Input.Translations[i].ResearcherName" class="form-label">@L["F_Researcher"]</label><input asp-for="Input.Translations[i].ResearcherName" class="form-control" /><span asp-validation-for="Input.Translations[i].ResearcherName" class="text-danger small"></span></div>
                <div class="mb-2"><label asp-for="Input.Translations[i].Title" class="form-label">@L["F_Title"]</label><input asp-for="Input.Translations[i].Title" class="form-control" /><span asp-validation-for="Input.Translations[i].Title" class="text-danger small"></span></div>
                <div class="mb-2"><label asp-for="Input.Translations[i].Summary" class="form-label">@L["F_Summary"]</label><textarea asp-for="Input.Translations[i].Summary" class="form-control" rows="2"></textarea></div>
                <div class="mb-2"><label asp-for="Input.Translations[i].Body" class="form-label">@L["F_Body"]</label><textarea asp-for="Input.Translations[i].Body" class="form-control" rows="4"></textarea></div>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">@L["Save"]</button>
    <a class="btn btn-outline-secondary" asp-page="Index">@L["Cancel"]</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
