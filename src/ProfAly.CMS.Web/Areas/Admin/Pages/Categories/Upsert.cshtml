@page
@using Microsoft.AspNetCore.Mvc.Localization
@model ProfAly.CMS.Web.Areas.Admin.Pages.Categories.UpsertModel
@inject IViewLocalizer L
@{
    ViewData["Title"] = (Model.IsEdit ? L["Edit"].Value : L["CreateNew"].Value) + " · " + L["Categories_Title"].Value;
    var cultures = Model.Cultures;
}

<h1 class="page-title">@ViewData["Title"]</h1>

<form method="post" class="tile" style="max-width:680px">
    <div asp-validation-summary="All" class="alert alert-danger py-2 px-3 small"
         style="@(ViewData.ModelState.IsValid ? "display:none" : "")"></div>
    <input type="hidden" asp-for="Input.Id" />

    <ul class="nav nav-tabs" role="tablist">
        @for (var i = 0; i < cultures.Count; i++)
        {
            var c = cultures[i];
            var label = c == "ar" ? L["LangArabic"] : c == "fr" ? L["LangFrench"] : L["LangEnglish"];
            <li class="nav-item"><button class="nav-link @(i == 0 ? "active" : "")" type="button"
                data-bs-toggle="tab" data-bs-target="#t-@c">@label</button></li>
        }
    </ul>
    <div class="tab-content border border-top-0 p-3 mb-3">
        @for (var i = 0; i < cultures.Count; i++)
        {
            var c = cultures[i];
            <div class="tab-pane fade @(i == 0 ? "show active" : "")" id="t-@c" dir="@(c == "ar" ? "rtl" : "ltr")">
                <input type="hidden" asp-for="Input.Translations[i].Culture" />
                <div class="mb-2">
                    <label asp-for="Input.Translations[i].Name" class="form-label">@L["F_Name"]</label>
                    <input asp-for="Input.Translations[i].Name" class="form-control" />
                    <span asp-validation-for="Input.Translations[i].Name" class="text-danger small"></span>
                </div>
                <div class="mb-2">
                    <label asp-for="Input.Translations[i].Slug" class="form-label">@L["F_Category_Slug"]</label>
                    <input asp-for="Input.Translations[i].Slug" class="form-control" dir="ltr" placeholder="auto" />
                </div>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">@L["Save"]</button>
    <a class="btn btn-outline-secondary" asp-page="Index">@L["Cancel"]</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
