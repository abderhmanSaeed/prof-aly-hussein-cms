{
  "DetailedErrors": false,
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "ProfAly": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    },
    "File": {
      "Directory": "Logs",
      "MinLevel": "Information",
      "DailyRolling": false
    }
  },
  "Backup": {
    "Enabled": true,
    "KeepLast": 0
  },
  "RateLimiting": {
    "GlobalPermitLimit": 240,
    "LoginPermitLimit": 10
  }
}
