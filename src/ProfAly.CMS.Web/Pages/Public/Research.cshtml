@page "/{culture:regex(^(ar|en|fr)$)}/research"
@model ProfAly.CMS.Web.Pages.Public.ResearchModel
@{
    ViewData["Title"] = L["Hero_Research_Title"].Value;
    ViewData["Description"] = L["Hero_Research_Lead"].Value;
}

<section class="page-hero">
    <div class="container">
        <nav class="crumbs"><a asp-page="/Public/Home" asp-route-culture="@Model.Culture">@L["Nav_Home"]</a> <span aria-hidden="true">/</span> <span aria-current="page">@L["Research_Title"]</span></nav>
        <span class="eyebrow">@L["Hero_Research_Title"]</span>
        <h1>@L["Hero_Research_Title"]</h1>
        <p class="section-lead">@L["Hero_Research_Lead"]</p>
    </div>
</section>

<section class="section">
    <div class="container">
        @if (Model.Items.Count == 0)
        {
            <div class="empty-state">
                <p class="empty-title">@L["Research_EmptyTitle"]</p>
                <p class="m-0">@L["Research_EmptyBody"]</p>
                <a class="btn btn-primary" asp-page="/Public/Publications" asp-route-culture="@Model.Culture">@L["Publications_Title"]</a>
            </div>
        }
        else
        {
            <ul class="pub-list">
                @foreach (var item in Model.Items)
                {
                    var t = Localized.Pick(item.Translations, Model.Culture);
                    <li class="pub-item">
                        <span class="pub-year">@item.PublicationYear</span>
                        <div class="pub-body">
                            <h3 class="pub-title">@t?.Title</h3>
                            @if (!string.IsNullOrEmpty(t?.Journal)) { <p class="pub-venue">@t.Journal</p> }
                            @if (item.PdfFile is { } pdf)
                            {
                                <div class="pub-actions">
                                    <a class="btn btn-outline btn-sm" href="/uploads/@pdf.RelativePath" target="_blank" rel="noopener">@L["Pub_ViewPdf"]</a>
                                    <a class="btn btn-outline btn-sm" href="/uploads/@pdf.RelativePath" download>@L["Pub_DownloadPdf"]</a>
                                </div>
                            }
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</section>
