@page "/{culture:regex(^(ar|en|fr)$)}/recommended-books"
@using ProfAly.CMS.Domain.Entities.Content
@model ProfAly.CMS.Web.Pages.Public.RecommendedBooksModel
@{
    ViewData["Title"] = L["RecommendedBooks_Title"].Value;
    ViewData["Description"] = L["RecommendedBooks_Lead"].Value;
}

<section class="page-hero">
    <div class="container">
        <nav class="crumbs"><a asp-page="/Public/Home" asp-route-culture="@Model.Culture">@L["Nav_Home"]</a> <span aria-hidden="true">/</span> <span aria-current="page">@L["RecommendedBooks_Title"]</span></nav>
        <span class="eyebrow">@L["Nav_DigitalResources"]</span>
        <h1>@L["RecommendedBooks_Title"]</h1>
        <p class="section-lead">@L["RecommendedBooks_Lead"]</p>
    </div>
</section>

@if (Model.Featured.Count > 0)
{
    <section class="section section--alt">
        <div class="container">
            <div class="section-head"><span class="eyebrow">@L["F_Featured"]</span><h2 class="section-title">@L["F_Featured"]</h2></div>
            <div class="card-grid">
                @foreach (var b in Model.Featured)
                {
                    <partial name="Shared/_BookCard" model="Model.CardFor(b)" />
                }
            </div>
        </div>
    </section>
}

<section class="section">
    <div class="container">
        <form class="search-bar" method="get" role="search">
            <input type="search" name="q" value="@Model.Query" class="search-input" dir="auto"
                   placeholder="@L["Search_Button"]" aria-label="@L["Search_Button"]" />
            <button type="submit" class="btn btn-primary">@L["Search_Button"]</button>
            @if (!string.IsNullOrEmpty(Model.Query))
            {
                <a class="btn btn-outline" asp-page="/Public/RecommendedBooks" asp-route-culture="@Model.Culture">@L["Search_Clear"]</a>
            }
        </form>
        @if (Model.Items.Count == 0) { <p class="empty-state">@L["Pub_NoItems"]</p> }
        <div class="card-grid">
            @foreach (var b in Model.Items)
            {
                <partial name="Shared/_BookCard" model="Model.CardFor(b)" />
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="text-center mt-section" aria-label="Pagination">
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <a class="btn @(i == Model.PageNum ? "btn-primary" : "btn-outline")" style="margin:.2rem"
                       asp-page="/Public/RecommendedBooks" asp-route-culture="@Model.Culture" asp-route-q="@Model.Query" asp-route-p="@i">@i</a>
                }
            </nav>
        }
    </div>
</section>
