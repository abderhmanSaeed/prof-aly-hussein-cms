@page "/{culture:regex(^(ar|en|fr)$)}/enrichment"
@using ProfAly.CMS.Domain.Entities.Content
@model ProfAly.CMS.Web.Pages.Public.EnrichmentModel
@{
    ViewData["Title"] = L["Enrichment_Title"].Value;
    ViewData["Description"] = L["Enrichment_Lead"].Value;
}

@functions {
    string SlugOf(EnrichmentItem e) => Localized.Pick(e.Translations, Model.Culture)?.Slug ?? string.Empty;
}

<section class="page-hero">
    <div class="container">
        <nav class="crumbs"><a asp-page="/Public/Home" asp-route-culture="@Model.Culture">@L["Nav_Home"]</a> <span aria-hidden="true">/</span> <span aria-current="page">@L["Enrichment_Title"]</span></nav>
        <span class="eyebrow">@L["Nav_DigitalResources"]</span>
        <h1>@L["Enrichment_Title"]</h1>
        <p class="section-lead">@L["Enrichment_Lead"]</p>
    </div>
</section>

@if (Model.Featured.Count > 0)
{
    <section class="section section--alt">
        <div class="container">
            <div class="section-head"><span class="eyebrow">@L["F_Featured"]</span><h2 class="section-title">@L["F_Featured"]</h2></div>
            <div class="card-grid">
                @foreach (var e in Model.Featured)
                {
                    var t = Localized.Pick(e.Translations, Model.Culture);
                    <a class="book-card" asp-page="/Public/EnrichmentDetail" asp-route-culture="@Model.Culture" asp-route-slug="@SlugOf(e)">
                        <div class="book-cover">
                            <span class="book-flag">@L["F_Featured"]</span>
                            @if (e.CoverImage is not null) { <img src="/uploads/@e.CoverImage.RelativePath" alt="@t?.Title" style="width:100%;height:100%;object-fit:cover" loading="lazy" /> }
                            else { <span class="initial">@(t?.Title?.Trim().Substring(0, 1))</span> }
                        </div>
                        <div class="book-info"><h3 class="book-title">@t?.Title</h3></div>
                    </a>
                }
            </div>
        </div>
    </section>
}

<section class="section">
    <div class="container">
        <form class="search-bar" method="get" role="search">
            <input type="search" name="q" value="@Model.Query" class="search-input" dir="auto"
                   placeholder="@L["Search_Button"]" aria-label="@L["Search_Button"]" />
            <button type="submit" class="btn btn-primary">@L["Search_Button"]</button>
            @if (!string.IsNullOrEmpty(Model.Query))
            {
                <a class="btn btn-outline" asp-page="/Public/Enrichment" asp-route-culture="@Model.Culture">@L["Search_Clear"]</a>
            }
        </form>
        @if (Model.Items.Count == 0) { <p class="empty-state">@L["Pub_NoItems"]</p> }
        <div class="card-grid">
            @foreach (var e in Model.Items)
            {
                var t = Localized.Pick(e.Translations, Model.Culture);
                <a class="book-card" asp-page="/Public/EnrichmentDetail" asp-route-culture="@Model.Culture" asp-route-slug="@SlugOf(e)">
                    <div class="book-cover">
                        @if (e.IsFeatured) { <span class="book-flag">@L["F_Featured"]</span> }
                        @if (e.CoverImage is not null) { <img src="/uploads/@e.CoverImage.RelativePath" alt="@t?.Title" style="width:100%;height:100%;object-fit:cover" loading="lazy" /> }
                        else { <span class="initial">@(t?.Title?.Trim().Substring(0, 1))</span> }
                    </div>
                    <div class="book-info">
                        <h3 class="book-title">@t?.Title</h3>
                        @if (!string.IsNullOrEmpty(t?.Summary)) { <p class="book-pub">@(t!.Summary!.Length > 110 ? t.Summary[..110] + "…" : t.Summary)</p> }
                    </div>
                </a>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="text-center mt-section" aria-label="Pagination">
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <a class="btn @(i == Model.PageNum ? "btn-primary" : "btn-outline")" style="margin:.2rem"
                       asp-page="/Public/Enrichment" asp-route-culture="@Model.Culture" asp-route-q="@Model.Query" asp-route-p="@i">@i</a>
                }
            </nav>
        }
    </div>
</section>
