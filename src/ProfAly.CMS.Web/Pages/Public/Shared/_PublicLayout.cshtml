@using System.Globalization
@{
    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    if (!SupportedCultures.IsSupported(culture)) { culture = SupportedCultures.Default; }
    var dir = culture == "ar" ? "rtl" : "ltr";
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "/Public/Home";

    string PathFor(string targetCulture)
    {
        var path = ViewContext.HttpContext.Request.Path.Value ?? "/";
        var segs = path.Split('/', StringSplitOptions.RemoveEmptyEntries).ToList();
        if (segs.Count > 0 && SupportedCultures.IsSupported(segs[0])) { segs[0] = targetCulture; }
        else { segs.Insert(0, targetCulture); }
        return "/" + string.Join('/', segs);
    }
    var req = ViewContext.HttpContext.Request;
    var baseUrl = $"{req.Scheme}://{req.Host}";
    var siteTitle = ViewData["SiteTitle"] as string ?? "Prof. Aly Hussein";

    // Research is intentionally omitted from public navigation & footer (business
    // decision — see 64_Navigation_And_Research_Page_Review.md). The /{c}/research
    // route still works if accessed directly; only the menu links are hidden.
    // Top-level nav. An item with Children renders as a dropdown (its own Page is null).
    // "Digital Resources" groups Educational Videos / Enrichment Materials / Recommended
    // Books (doc 76); "Events" is a new top-level item.
    var nav = new (string Key, string? Page, (string Key, string Page)[]? Children)[]
    {
        ("Nav_Home", "/Public/Home", null), ("Nav_About", "/Public/About", null),
        ("Nav_Experience", "/Public/Experience", null), ("Nav_Activities", "/Public/Activities", null),
        ("Nav_Publications", "/Public/Publications", null), ("Nav_Books", "/Public/Books", null),
        ("Nav_Theses", "/Public/Theses", null),
        ("Nav_DigitalResources", null, new[]
        {
            ("Nav_EducationalVideos", "/Public/Videos"),
            ("Nav_Enrichment", "/Public/Enrichment"),
            ("Nav_RecommendedBooks", "/Public/RecommendedBooks"),
        }),
        ("Nav_Events", "/Public/Events", null),
        ("Nav_Teaching", "/Public/Teaching", null), ("Nav_Contact", "/Public/Contact", null),
    };

    // Flattened (label, page) pairs for the footer quick-links column.
    var footerLinks = nav.SelectMany(n => n.Children is null
        ? new[] { (n.Key, n.Page!) }
        : n.Children).ToArray();

    bool DropdownActive((string Key, string Page)[] children) =>
        children.Any(c => currentPage == c.Page);
}
<!doctype html>
<html lang="@culture" dir="@dir" data-lang="@culture" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · @siteTitle</title>
    <meta name="description" content="@ViewData["Description"]" />
    <link rel="canonical" href="@(baseUrl + PathFor(culture))" />
    @foreach (var c in SupportedCultures.All)
    {
        <link rel="alternate" hreflang="@c" href="@(baseUrl + PathFor(c))" />
    }
    <link rel="alternate" hreflang="x-default" href="@(baseUrl + PathFor(SupportedCultures.Default))" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@ViewData["Title"]" />
    <meta property="og:description" content="@ViewData["Description"]" />
    <meta name="theme-color" content="#0B5D3B" />
    <script>(function(){try{var t=localStorage.getItem("theme")||"light";document.documentElement.setAttribute("data-theme",t);}catch(e){}})();</script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@400;600;700&family=Cormorant+Garamond:wght@600;700&family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap@(culture == "ar" ? ".rtl" : "").min.css" />
    <link rel="stylesheet" href="~/css/public.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main">@L["Skip_To_Content"]</a>
    <header class="site-nav">
        <nav class="container nav-inner" aria-label="@siteTitle">
            <a class="brand" asp-page="/Public/Home" asp-route-culture="@culture">
                <span class="brand-mark" aria-hidden="true">ع</span>
                <span class="brand-text"><span>@siteTitle</span><span class="sub">@ViewData["Tagline"]</span></span>
            </a>
            <ul class="nav-menu" id="primary-nav">
                @foreach (var item in nav)
                {
                    if (item.Children is null)
                    {
                        <li><a class="@(currentPage == item.Page ? "active" : "")" asp-page="@item.Page" asp-route-culture="@culture" aria-current="@(currentPage == item.Page ? "page" : null)">@L[item.Key]</a></li>
                    }
                    else
                    {
                        var ddActive = DropdownActive(item.Children);
                        <li class="nav-dropdown">
                            <button type="button" class="nav-dropdown-toggle @(ddActive ? "active" : "")" aria-haspopup="true" aria-expanded="false">
                                @L[item.Key]<span class="caret" aria-hidden="true">▾</span>
                            </button>
                            <ul class="nav-dropdown-menu">
                                @foreach (var child in item.Children)
                                {
                                    <li><a class="@(currentPage == child.Page ? "active" : "")" asp-page="@child.Page" asp-route-culture="@culture" aria-current="@(currentPage == child.Page ? "page" : null)">@L[child.Key]</a></li>
                                }
                            </ul>
                        </li>
                    }
                }
            </ul>
            <div class="nav-actions">
                <button class="icon-btn theme-toggle" type="button" title="Theme" aria-label="Theme">&#9681;</button>
                @foreach (var c in SupportedCultures.All)
                {
                    <a class="lang-link @(c == culture ? "active" : "")" asp-page="@currentPage" asp-route-culture="@c"
                       hreflang="@c" lang="@c" aria-current="@(c == culture ? "true" : null)">@c.ToUpperInvariant()</a>
                }
                <button class="icon-btn nav-burger d-xl-none" type="button" aria-label="Menu" aria-controls="primary-nav" aria-expanded="false">&#9776;</button>
            </div>
        </nav>
    </header>

    <main id="main" tabindex="-1">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-12 col-lg-4">
                    <div class="footer-brand">
                        <span class="brand-mark" aria-hidden="true">ع</span>
                        <span class="brand-name">@siteTitle</span>
                    </div>
                    @if (ViewData["Tagline"] is string tg && !string.IsNullOrEmpty(tg)) { <p class="footer-tagline">@tg</p> }
                    <p class="footer-built">@L["Footer_Built"]</p>
                </div>
                <nav class="col-12 col-md-7 col-lg-5" aria-label="@L["Footer_QuickLinks"]">
                    <h2 class="footer-h">@L["Footer_QuickLinks"]</h2>
                    <ul class="footer-links">
                        @foreach (var item in footerLinks)
                        {
                            <li><a asp-page="@item.Item2" asp-route-culture="@culture">@L[item.Item1]</a></li>
                        }
                    </ul>
                </nav>
                <div class="col-12 col-md-5 col-lg-3">
                    <h2 class="footer-h">@L["Footer_Contact"]</h2>
                    <ul class="footer-contact">
                        @if (ViewData["ContactEmail"] is string em && !string.IsNullOrEmpty(em)) { <li><a href="mailto:@em" dir="ltr">@em</a></li> }
                        @if (ViewData["ContactPhone"] is string ph && !string.IsNullOrEmpty(ph)) { <li><a href="tel:@ph" dir="ltr">@ph</a></li> }
                        @if (ViewData["ContactLocation"] is string loc && !string.IsNullOrEmpty(loc)) { <li class="footer-loc">@loc</li> }
                    </ul>
                </div>
            </div>
            <div class="footer-base">© @DateTime.UtcNow.Year @siteTitle. @L["Footer_Rights"]</div>
        </div>
    </footer>

    <button class="back-to-top" type="button" aria-label="@L["Back_To_Top"]" title="@L["Back_To_Top"]">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/public.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
