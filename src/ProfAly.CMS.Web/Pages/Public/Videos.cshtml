@page "/{culture:regex(^(ar|en|fr)$)}/videos"
@using ProfAly.CMS.Domain.Common
@using ProfAly.CMS.Domain.Entities.Content
@model ProfAly.CMS.Web.Pages.Public.VideosModel
@{
    ViewData["Title"] = L["Videos_Title"].Value;
    ViewData["Description"] = L["Videos_Title"].Value;
}

@functions {
    string SlugOf(Video v) => (Localized.Pick(v.Translations, Model.Culture)?.Slug) ?? string.Empty;
}

<section class="page-hero">
    <div class="container">
        <nav class="crumbs"><a asp-page="/Public/Home" asp-route-culture="@Model.Culture">@L["Nav_Home"]</a> <span aria-hidden="true">/</span> <span aria-current="page">@L["Videos_Title"]</span></nav>
        <span class="eyebrow">@L["Videos_Title"]</span>
        <h1>@L["Videos_Title"]</h1>
    </div>
</section>

@if (Model.Featured.Count > 0)
{
    <section class="section section--alt">
        <div class="container">
            <div class="section-head"><span class="eyebrow">@L["Videos_Featured"]</span><h2 class="section-title">@L["Videos_Featured"]</h2></div>
            <div class="card-grid">
                @foreach (var v in Model.Featured)
                {
                    var t = Localized.Pick(v.Translations, Model.Culture);
                    <a class="book-card" asp-page="/Public/VideoDetail" asp-route-culture="@Model.Culture" asp-route-slug="@SlugOf(v)">
                        <div class="book-cover" style="aspect-ratio:16/9;background:#000">
                            <span class="book-flag">@L["F_Featured"]</span>
                            <img src="@YouTube.ThumbnailUrl(v.YouTubeVideoId)" alt="@t?.Title" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
                            <span class="video-play" aria-hidden="true">▶</span>
                        </div>
                        <div class="book-info"><h3 class="book-title">@t?.Title</h3></div>
                    </a>
                }
            </div>
        </div>
    </section>
}

<section class="section">
    <div class="container">
        @if (Model.Items.Count == 0) { <p class="empty-state">@L["Pub_NoItems"]</p> }
        <div class="card-grid">
            @foreach (var v in Model.Items)
            {
                var t = Localized.Pick(v.Translations, Model.Culture);
                <a class="book-card" asp-page="/Public/VideoDetail" asp-route-culture="@Model.Culture" asp-route-slug="@SlugOf(v)">
                    <div class="book-cover" style="aspect-ratio:16/9;background:#000">
                        <img src="@YouTube.ThumbnailUrl(v.YouTubeVideoId)" alt="@t?.Title" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
                        <span class="video-play" aria-hidden="true">▶</span>
                    </div>
                    <div class="book-info">
                        <h3 class="book-title">@t?.Title</h3>
                        @if (!string.IsNullOrEmpty(t?.Summary)) { <p class="book-pub">@(t.Summary!.Length > 110 ? t.Summary[..110] + "…" : t.Summary)</p> }
                    </div>
                </a>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="text-center mt-section" aria-label="Pagination">
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <a class="btn @(i == Model.PageNum ? "btn-primary" : "btn-outline")" style="margin:.2rem"
                       asp-page="/Public/Videos" asp-route-culture="@Model.Culture" asp-route-p="@i">@i</a>
                }
            </nav>
        }
    </div>
</section>
