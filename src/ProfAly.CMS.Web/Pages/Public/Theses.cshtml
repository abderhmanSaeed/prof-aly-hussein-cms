@page "/{culture:regex(^(ar|en|fr)$)}/theses"
@using ProfAly.CMS.Domain.Enums
@model ProfAly.CMS.Web.Pages.Public.ThesesModel
@{
    ViewData["Title"] = L["Hero_Theses_Title"].Value;
    ViewData["Description"] = L["Hero_Theses_Lead"].Value;
    string Cat(RelationshipType r) => r switch { RelationshipType.Examined => "examined", RelationshipType.Ongoing => "ongoing", _ => "supervised" };
    string CatLabel(RelationshipType r) => (r == RelationshipType.Examined ? L["Rel_Examined"] : r == RelationshipType.Ongoing ? L["Rel_Ongoing"] : L["Rel_Supervised"]).Value;
}

<section class="page-hero">
    <div class="container">
        <nav class="crumbs"><a asp-page="/Public/Home" asp-route-culture="@Model.Culture">@L["Nav_Home"]</a> <span aria-hidden="true">/</span> <span aria-current="page">@L["Theses_Title"]</span></nav>
        <span class="eyebrow">@L["Hero_Theses_Title"]</span>
        <h1>@L["Hero_Theses_Title"]</h1>
        <p class="section-lead">@L["Hero_Theses_Lead"]</p>
    </div>
</section>

<section class="section">
    <div class="container">
        @{ var allLabel = Model.Culture == "ar" ? "الكل" : Model.Culture == "fr" ? "Tous" : "All"; }
        <div class="filter-tabs">
            <button class="filter-tab active" data-cat="all" type="button">@allLabel</button>
            <button class="filter-tab" data-cat="supervised" type="button">@L["Rel_Supervised"]</button>
            <button class="filter-tab" data-cat="examined" type="button">@L["Rel_Examined"]</button>
            <button class="filter-tab" data-cat="ongoing" type="button">@L["Rel_Ongoing"]</button>
        </div>

        @if (Model.Items.Count == 0)
        {
            <p class="empty-state">@L["Pub_NoItems"]</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="theses-table">
                    <caption class="visually-hidden">@L["Theses_Title"]</caption>
                    <thead>
                        <tr>
                            <th scope="col">@L["F_Researcher"]</th><th scope="col">@L["F_Title"]</th><th scope="col">@L["F_Degree"]</th>
                            <th scope="col">@L["F_Relationship"]</th><th scope="col">@L["F_PublicationYear"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            var t = Localized.Pick(item.Translations, Model.Culture);
                            <tr data-thesis-row data-cat="@Cat(item.RelationshipType)">
                                <td data-label="@L["F_Researcher"].Value">@t?.ResearcherName</td>
                                <td data-label="@L["F_Title"].Value">@t?.Title</td>
                                <td data-label="@L["F_Degree"].Value"><span class="badge-deg badge-@(item.DegreeLevel == DegreeLevel.PhD ? "PhD" : "MA")">@(item.DegreeLevel == DegreeLevel.PhD ? L["Deg_PhD"] : L["Deg_Master"])</span></td>
                                <td data-label="@L["F_Relationship"].Value"><span class="badge-cat badge-@Cat(item.RelationshipType)">@CatLabel(item.RelationshipType)</span></td>
                                <td data-label="@L["F_PublicationYear"].Value" class="th-year">@item.PublicationYear</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
