@page "/{culture:regex(^(ar|en|fr)$)}/theses"
@using ProfAly.CMS.Domain.Enums
@model ProfAly.CMS.Web.Pages.Public.ThesesModel
@{
    ViewData["Title"] = L["Theses_Title"].Value;
    ViewData["Description"] = L["Theses_Title"].Value;
    string Cat(RelationshipType r) => r switch { RelationshipType.Examined => "examined", RelationshipType.Ongoing => "ongoing", _ => "supervised" };
    string CatLabel(RelationshipType r) => (r == RelationshipType.Examined ? L["Rel_Examined"] : r == RelationshipType.Ongoing ? L["Rel_Ongoing"] : L["Rel_Supervised"]).Value;
}

<section class="page-hero">
    <div class="container">
        <nav class="crumbs"><a asp-page="/Public/Home" asp-route-culture="@Model.Culture">@L["Nav_Home"]</a> / @L["Theses_Title"]</nav>
        <span class="eyebrow">@L["Theses_Title"]</span>
        <h1>@L["Theses_Title"]</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        @{ var allLabel = Model.Culture == "ar" ? "الكل" : Model.Culture == "fr" ? "Tous" : "All"; }
        <div class="filter-tabs">
            <button class="filter-tab active" data-cat="all" type="button">@allLabel</button>
            <button class="filter-tab" data-cat="supervised" type="button">@L["Rel_Supervised"]</button>
            <button class="filter-tab" data-cat="examined" type="button">@L["Rel_Examined"]</button>
            <button class="filter-tab" data-cat="ongoing" type="button">@L["Rel_Ongoing"]</button>
        </div>

        <div class="table-wrap">
            <table class="theses-table">
                <thead>
                    <tr>
                        <th>@L["F_Researcher"]</th><th>@L["F_Title"]</th><th>@L["F_Degree"]</th>
                        <th>@L["F_Relationship"]</th><th>@L["F_PublicationYear"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0) { <tr><td colspan="5" class="empty-state">@L["Pub_NoItems"]</td></tr> }
                    @foreach (var item in Model.Items)
                    {
                        var t = Localized.Pick(item.Translations, Model.Culture);
                        <tr data-thesis-row data-cat="@Cat(item.RelationshipType)">
                            <td>@t?.ResearcherName</td>
                            <td>@t?.Title</td>
                            <td><span class="badge-deg badge-@(item.DegreeLevel == DegreeLevel.PhD ? "PhD" : "MA")">@(item.DegreeLevel == DegreeLevel.PhD ? L["Deg_PhD"] : L["Deg_Master"])</span></td>
                            <td>@CatLabel(item.RelationshipType)</td>
                            <td>@item.PublicationYear</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
