@page "/{culture:regex(^(ar|en|fr)$)}"
@using System.Globalization
@model ProfAly.CMS.Web.Pages.Public.HomeModel
@{
    var p = Localized.Pick(Model.Profile?.Translations, Model.Culture);
    var hasBio = !string.IsNullOrWhiteSpace(p?.FullBio) || !string.IsNullOrWhiteSpace(p?.ShortBio);
    var photo = Model.Profile?.Photo is null ? null : "/uploads/" + Model.Profile.Photo.RelativePath;
    var bioImage = Model.Profile?.BioImage is null ? null : "/uploads/" + Model.Profile.BioImage.RelativePath;
    var badge = Model.Stats.FirstOrDefault();
    var badgeText = badge is null ? null : Localized.Pick(badge.Translations, Model.Culture)?.Label;
    ViewData["Title"] = p?.FullName ?? "Prof. Aly Hussein";
    ViewData["Description"] = BioContent.PlainText(p?.Positioning) ?? BioContent.PlainText(p?.ShortBio);
}

<section class="hero">
    <div class="container">
        <div class="hero-grid">
            <div class="hero-copy">
                <span class="hero-eyebrow"><span class="dot" aria-hidden="true"></span><span>@ViewData["Tagline"]</span></span>
                <h1 class="hero-name">@p?.FullName</h1>
                <p class="hero-title">@p?.Title</p>
                <p class="hero-positioning">@BioContent.RenderInline(p?.Positioning)</p>
                <div class="hero-cta">
                    <a class="btn btn-primary" asp-page="/Public/Publications" asp-route-culture="@Model.Culture">@L["Hero_CtaResearch"]</a>
                    <a class="btn btn-outline" asp-page="/Public/Contact" asp-route-culture="@Model.Culture">@L["Hero_CtaContact"]</a>
                </div>
            </div>
            <div class="hero-portrait-wrap">
                <div class="hero-portrait">
                    @if (photo is not null) { <img src="@photo" alt="@p?.FullName" /> }
                    else { <div class="hero-portrait-fallback" aria-hidden="true">ع</div> }
                </div>
                @if (badge is not null)
                {
                    <div class="hero-badge">
                        <span class="b-num">@badge.Value@badge.Suffix</span>
                        <span class="b-txt">@badgeText</span>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@if (Model.Credibility.Count > 0)
{
    <section class="section section--alt">
        <div class="container">
            <div class="section-head center"><span class="eyebrow">@L["Pub_Institutions"]</span></div>
            <div class="cred-row">
                @foreach (var c in Model.Credibility)
                {
                    <span class="chip">@(Localized.Pick(c.Translations, Model.Culture)?.Name)</span>
                }
            </div>
        </div>
    </section>
}

@if (Model.Stats.Count > 0)
{
    <section class="section">
        <div class="container">
            <div class="section-head center"><span class="eyebrow">@L["Pub_InNumbers"]</span><h2 class="section-title">@L["Pub_InNumbers"]</h2></div>
            <div class="stats-row">
                @foreach (var s in Model.Stats)
                {
                    <div class="stat-card">
                        <div class="stat-num" data-target="@s.Value" data-suffix="@s.Suffix">0</div>
                        <div class="stat-label">@(Localized.Pick(s.Translations, Model.Culture)?.Label)</div>
                    </div>
                }
            </div>
        </div>
    </section>
}

@if (hasBio)
{
    <section class="section section--alt">
        <div class="container">
            <div class="snapshot-grid">
                <div class="snapshot-photo">
                    @if (bioImage is not null) { <img src="@bioImage" alt="@p?.FullName" /> }
                    else { <div class="snapshot-photo-fallback" aria-hidden="true">ع</div> }
                </div>
                <div class="snapshot-text">
                    <span class="eyebrow">@L["Pub_AboutShort"]</span>
                    <h2 class="section-title">@L["Pub_AboutShort"]</h2>
                    <div class="content-body">@BioContent.RenderTeaser(p?.FullBio, p?.ShortBio)</div>
                    <a class="btn btn-outline" asp-page="/Public/About" asp-route-culture="@Model.Culture">@L["Pub_ReadBio"]</a>
                </div>
            </div>
        </div>
    </section>
}

@if (Model.FeaturedBooks.Count > 0)
{
    <section class="section">
        <div class="container">
            <div class="section-head center"><span class="eyebrow">@L["Pub_FeaturedBooks"]</span><h2 class="section-title">@L["Pub_FeaturedBooks"]</h2></div>
            <div class="card-grid card-grid--4">
                @foreach (var b in Model.FeaturedBooks)
                {
                    <partial name="Shared/_BookCard" model="Model.CardForBook(b)" />
                }
            </div>
            <div class="text-center mt-section"><a class="btn btn-outline" asp-page="/Public/Books" asp-route-culture="@Model.Culture">@L["Pub_ViewAll"]</a></div>
        </div>
    </section>
}

@if (Model.LatestVideos.Count > 0)
{
    <section class="section section--alt">
        <div class="container">
            <div class="section-head center"><span class="eyebrow">@L["Nav_DigitalResources"]</span><h2 class="section-title">@L["Home_LatestVideos"]</h2></div>
            <div class="card-grid card-grid--4">
                @foreach (var v in Model.LatestVideos)
                {
                    var vt = Localized.Pick(v.Translations, Model.Culture);
                    <a class="book-card" asp-page="/Public/VideoDetail" asp-route-culture="@Model.Culture" asp-route-slug="@(vt?.Slug)">
                        <div class="book-cover" style="aspect-ratio:16/9;background:#000">
                            <img src="@YouTube.ThumbnailUrl(v.YouTubeVideoId)" alt="@vt?.Title" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
                            <span class="video-play" aria-hidden="true">▶</span>
                        </div>
                        <div class="book-info"><h3 class="book-title">@vt?.Title</h3></div>
                    </a>
                }
            </div>
            <div class="text-center mt-section"><a class="btn btn-outline" asp-page="/Public/Videos" asp-route-culture="@Model.Culture">@L["Pub_ViewAll"]</a></div>
        </div>
    </section>
}

@if (Model.LatestEnrichment.Count > 0)
{
    <section class="section">
        <div class="container">
            <div class="section-head center"><span class="eyebrow">@L["Nav_DigitalResources"]</span><h2 class="section-title">@L["Home_LatestEnrichment"]</h2></div>
            <div class="card-grid card-grid--4">
                @foreach (var e in Model.LatestEnrichment)
                {
                    var et = Localized.Pick(e.Translations, Model.Culture);
                    <a class="book-card" asp-page="/Public/EnrichmentDetail" asp-route-culture="@Model.Culture" asp-route-slug="@(et?.Slug)">
                        <div class="book-cover">
                            @if (e.CoverImage is not null) { <img src="/uploads/@e.CoverImage.RelativePath" alt="@et?.Title" style="width:100%;height:100%;object-fit:cover" loading="lazy" /> }
                            else { <span class="initial">@(et?.Title?.Trim().Substring(0, 1))</span> }
                        </div>
                        <div class="book-info"><h3 class="book-title">@et?.Title</h3></div>
                    </a>
                }
            </div>
            <div class="text-center mt-section"><a class="btn btn-outline" asp-page="/Public/Enrichment" asp-route-culture="@Model.Culture">@L["Pub_ViewAll"]</a></div>
        </div>
    </section>
}

@if (Model.RecommendedBooks.Count > 0)
{
    <section class="section section--alt">
        <div class="container">
            <div class="section-head center"><span class="eyebrow">@L["Nav_DigitalResources"]</span><h2 class="section-title">@L["Home_RecommendedBooks"]</h2></div>
            <div class="card-grid card-grid--4">
                @foreach (var b in Model.RecommendedBooks)
                {
                    <partial name="Shared/_BookCard" model="Model.CardForRecommended(b)" />
                }
            </div>
            <div class="text-center mt-section"><a class="btn btn-outline" asp-page="/Public/RecommendedBooks" asp-route-culture="@Model.Culture">@L["Pub_ViewAll"]</a></div>
        </div>
    </section>
}

@if (Model.FeaturedEvents.Count > 0)
{
    <section class="section">
        <div class="container">
            <div class="section-head center"><span class="eyebrow">@L["Events_Title"]</span><h2 class="section-title">@L["Home_FeaturedEvents"]</h2></div>
            <div class="card-grid card-grid--4">
                @foreach (var e in Model.FeaturedEvents)
                {
                    var et = Localized.Pick(e.Translations, Model.Culture);
                    <a class="book-card" asp-page="/Public/EventDetail" asp-route-culture="@Model.Culture" asp-route-slug="@(et?.Slug)">
                        <div class="book-cover" style="aspect-ratio:16/9">
                            @if (e.IsFeatured) { <span class="book-flag">@L["F_Featured"]</span> }
                            @if (e.CoverImage is not null) { <img src="/uploads/@e.CoverImage.RelativePath" alt="@et?.Title" style="width:100%;height:100%;object-fit:cover" loading="lazy" /> }
                            else { <span class="initial">@(et?.Title?.Trim().Substring(0, 1))</span> }
                        </div>
                        <div class="book-info">
                            <h3 class="book-title">@et?.Title</h3>
                            @if (e.EventDateUtc is { } ed) { <p class="book-pub">@ed.ToString("d MMMM yyyy", CultureInfo.CurrentUICulture)</p> }
                        </div>
                    </a>
                }
            </div>
            <div class="text-center mt-section"><a class="btn btn-outline" asp-page="/Public/Events" asp-route-culture="@Model.Culture">@L["Pub_ViewAll"]</a></div>
        </div>
    </section>
}

<section class="section section--alt">
    <div class="container">
        <div class="cta-band">
            <h2>@p?.FullName</h2>
            <p>@BioContent.RenderInline(p?.ContactIntro)</p>
            <a class="btn btn-gold" asp-page="/Public/Contact" asp-route-culture="@Model.Culture">@L["Hero_CtaContact"]</a>
        </div>
    </div>
</section>

@section Scripts { }
