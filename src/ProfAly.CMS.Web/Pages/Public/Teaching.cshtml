@page "/{culture:regex(^(ar|en|fr)$)}/teaching"
@model ProfAly.CMS.Web.Pages.Public.TeachingModel
@{
    ViewData["Title"] = L["Hero_Teaching_Title"].Value;
    ViewData["Description"] = L["Hero_Teaching_Lead"].Value;
}

<section class="page-hero">
    <div class="container">
        <nav class="crumbs"><a asp-page="/Public/Home" asp-route-culture="@Model.Culture">@L["Nav_Home"]</a> / @L["Teaching_Title"]</nav>
        <span class="eyebrow">@L["Hero_Teaching_Title"]</span>
        <h1>@L["Hero_Teaching_Title"]</h1>
        <p class="section-lead">@L["Hero_Teaching_Lead"]</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6">
                <h2 class="section-title">@L["Pub_Undergraduate"]</h2>
                <ul class="course-list">
                    @foreach (var c in Model.Undergraduate)
                    {
                        var t = Localized.Pick(c.Translations, Model.Culture);
                        <li class="course-item"><div><p class="course-name">@t?.CourseName</p>@if (!string.IsNullOrEmpty(t?.Institution)){<p class="course-inst">@t.Institution</p>}</div></li>
                    }
                    @if (Model.Undergraduate.Count == 0) { <li class="empty-state">@L["Pub_NoItems"]</li> }
                </ul>
            </div>
            <div class="col-lg-6">
                <h2 class="section-title">@L["Pub_Graduate"]</h2>
                <ul class="course-list">
                    @foreach (var c in Model.Graduate)
                    {
                        var t = Localized.Pick(c.Translations, Model.Culture);
                        <li class="course-item"><div><p class="course-name">@t?.CourseName</p>@if (!string.IsNullOrEmpty(t?.Institution)){<p class="course-inst">@t.Institution</p>}</div></li>
                    }
                    @if (Model.Graduate.Count == 0) { <li class="empty-state">@L["Pub_NoItems"]</li> }
                </ul>
            </div>
        </div>
    </div>
</section>
