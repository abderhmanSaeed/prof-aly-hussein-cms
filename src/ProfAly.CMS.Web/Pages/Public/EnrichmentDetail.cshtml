@page "/{culture:regex(^(ar|en|fr)$)}/enrichment/{slug}"
@using ProfAly.CMS.Domain.Entities.Content
@model ProfAly.CMS.Web.Pages.Public.EnrichmentDetailModel
@{
    var t = Localized.Pick(Model.Item?.Translations, Model.Culture);
    ViewData["Title"] = (t?.MetaTitle ?? t?.Title) ?? L["Enrichment_Title"].Value;
    ViewData["Description"] = t?.MetaDescription ?? t?.Summary;

    var pdfPath = Model.Item?.PdfFile is null ? null : "/uploads/" + Model.Item.PdfFile.RelativePath;
    var pdfName = Model.Item?.PdfFile?.OriginalFileName;
    var url = Model.Item?.ExternalUrl;

    string SlugOf(EnrichmentItem e) => Localized.Pick(e.Translations, Model.Culture)?.Slug ?? string.Empty;
}

<section class="page-hero">
    <div class="container">
        <nav class="crumbs">
            <a asp-page="/Public/Home" asp-route-culture="@Model.Culture">@L["Nav_Home"]</a>
            <span aria-hidden="true">/</span>
            <a asp-page="/Public/Enrichment" asp-route-culture="@Model.Culture">@L["Enrichment_Title"]</a>
            <span aria-hidden="true">/</span>
            <span aria-current="page">@t?.Title</span>
        </nav>
        <h1>@t?.Title</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-8">
                @if (Model.Item!.CoverImage is not null)
                {
                    <img src="/uploads/@Model.Item.CoverImage.RelativePath" alt="@t?.Title" class="img-fluid rounded mb-4" style="width:100%;object-fit:cover" />
                }
                @if (!string.IsNullOrWhiteSpace(t?.Summary)) { <p class="lead">@t!.Summary</p> }
                @if (!string.IsNullOrWhiteSpace(t?.Body))
                {
                    <div class="content-body">@foreach (var para in t!.Body!.Split("\n\n", StringSplitOptions.RemoveEmptyEntries)) { <p>@para</p> }</div>
                }

                <div class="d-flex flex-wrap gap-2 mt-4">
                    @if (pdfPath is not null)
                    {
                        <a class="btn btn-primary" href="@pdfPath" target="_blank" rel="noopener">@L["Action_PreviewPdf"]</a>
                        <a class="btn btn-outline" href="@pdfPath" download="@pdfName">@L["Action_DownloadPdf"]</a>
                    }
                    @if (!string.IsNullOrWhiteSpace(url))
                    {
                        <a class="btn btn-outline" href="@url" target="_blank" rel="noopener noreferrer">@L["Action_VisitResource"]</a>
                    }
                </div>
            </div>
            <div class="col-lg-4">
                @if (Model.Related.Count > 0)
                {
                    <h2 class="panel-title">@L["Enrichment_Related"]</h2>
                    <div class="d-grid gap-3">
                        @foreach (var e in Model.Related)
                        {
                            var rt = Localized.Pick(e.Translations, Model.Culture);
                            <a class="related-video" asp-page="/Public/EnrichmentDetail" asp-route-culture="@Model.Culture" asp-route-slug="@SlugOf(e)">
                                @if (e.CoverImage is not null) { <img src="/uploads/@e.CoverImage.RelativePath" alt="@rt?.Title" loading="lazy" /> }
                                <span>@rt?.Title</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>
