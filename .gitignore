App_Data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ---- ASP.NET Core local secrets / local-only config ----
secrets.json
appsettings.*.local.json
*.user.json

# ---- Visual Studio ----
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.VisualState.xml
*_i.c
*_p.c

# ---- JetBrains Rider / ReSharper ----
.idea/
*.iml
*.DotSettings.user
_ReSharper*/

# ---- Visual Studio Code ----
.vscode/

# ---- Claude Code / local agent settings ----
.claude/

